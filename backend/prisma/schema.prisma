generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Staff / auth
// ─────────────────────────────────────────────────────────────────────────

enum StaffRole {
  MANAGEMENT
  ROOMS
  RESTAURANT
  LIQUOR
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CASUAL
  CONTRACT
}

model Staff {
  id        String    @id @default(cuid())
  fullName  String
  pinHash   String
  role      StaffRole
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  // HR profile — optional so existing/quickly-added accounts don't require filling everything in.
  employeeNumber  String?        @unique
  jobTitle        String?
  phone           String?
  email           String?
  address         String?
  dateOfBirth     DateTime?      @db.Date
  nationalId      String?
  dateHired       DateTime?      @db.Date
  employmentType  EmploymentType @default(FULL_TIME)
  baseSalary      Decimal?       @db.Decimal(10, 2)
  annualLeaveDays Int            @default(21)

  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?

  assignedOrders        Order[]
  liquorTransfers       LiquorTransfer[]
  roomSupplyAdjustments RoomSupplyAdjustment[]
  ingredientAdjustments IngredientAdjustment[]
  shifts                StaffShift[]
  attendanceRecords     AttendanceRecord[]
  leaveRequests         LeaveRequest[]         @relation("StaffLeaveRequests")
  reviewedLeaveRequests LeaveRequest[]         @relation("LeaveReviewedBy")
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

// One assigned shift per staff member per day (roster/rota).
model StaffShift {
  id        String    @id @default(cuid())
  staffId   String
  staff     Staff     @relation(fields: [staffId], references: [id])
  date      DateTime  @db.Date
  shiftType ShiftType
  notes     String?
  createdAt DateTime  @default(now())

  @@unique([staffId, date])
}

// Clock in/out record. clockOutAt null means the staff member is currently clocked in.
model AttendanceRecord {
  id         String    @id @default(cuid())
  staffId    String
  staff      Staff     @relation(fields: [staffId], references: [id])
  clockInAt  DateTime  @default(now())
  clockOutAt DateTime?
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id           String      @id @default(cuid())
  staffId      String
  staff        Staff       @relation("StaffLeaveRequests", fields: [staffId], references: [id])
  leaveType    LeaveType
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  reason       String?
  status       LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedBy   Staff?      @relation("LeaveReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Rooms module
// ─────────────────────────────────────────────────────────────────────────

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CLEANING
  MAINTENANCE
}

// Independent from RoomStatus: tracks the physical cleanliness of the room, not its
// booking availability. CLEAN flips a CLEANING room back to AVAILABLE; REPAIR flips
// the room to MAINTENANCE (see rooms.service.setHousekeeping).
enum HousekeepingStatus {
  CLEAN
  NOT_CLEAN
  IN_PROGRESS
  REPAIR
}

enum BookingStatus {
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum SourceModule {
  ROOM
  RESTAURANT
}

model RoomType {
  id                 String                  @id @default(cuid())
  name               String
  basePrice          Decimal                 @db.Decimal(10, 2)
  capacity           Int
  description        String?
  rooms              Room[]
  supplyRequirements RoomSupplyRequirement[]
}

model Room {
  id                String                 @id @default(cuid())
  number            String                 @unique
  keyNumber         String
  floor             Int
  status            RoomStatus             @default(AVAILABLE)
  housekeeping      HousekeepingStatus     @default(CLEAN)
  roomTypeId        String
  roomType          RoomType               @relation(fields: [roomTypeId], references: [id])
  bookings          Booking[]
  supplyAdjustments RoomSupplyAdjustment[]
}

model Guest {
  id       String    @id @default(cuid())
  fullName String
  phone    String?
  email    String?
  idNumber String?
  bookings Booking[]
}

model Booking {
  id                 String        @id @default(cuid())
  roomId             String
  room               Room          @relation(fields: [roomId], references: [id])
  guestId            String
  guest              Guest         @relation(fields: [guestId], references: [id])
  checkInAt          DateTime      @default(now())
  expectedCheckOutAt DateTime
  checkOutAt         DateTime?
  ratePerNight       Decimal       @db.Decimal(10, 2) // flat charge for the stay when isShortStay, else per-night rate
  isShortStay        Boolean       @default(false)
  status             BookingStatus @default(CHECKED_IN)
  notes              String?
  folioCharges       FolioCharge[]
  restaurantOrders   Order[]
  createdAt          DateTime      @default(now())
}

model FolioCharge {
  id           String       @id @default(cuid())
  bookingId    String
  booking      Booking      @relation(fields: [bookingId], references: [id])
  sourceModule SourceModule
  description  String
  amount       Decimal      @db.Decimal(10, 2)
  createdAt    DateTime     @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Room supplies — housekeeping's central store (linen, toiletries, guest
// amenities, cleaning stock). Par levels (RoomSupplyRequirement) define how
// much of each item a room type consumes per turnover; marking a room CLEAN
// in housekeeping auto-consumes those quantities from central stock (see
// rooms.service.setHousekeeping). CLEANING-category items (cart chemicals
// etc.) are tracked for stock/restock but have no par level — they're drawn
// across many rooms rather than consumed 1:1 per clean.
// ─────────────────────────────────────────────────────────────────────────

enum RoomSupplyCategory {
  LINEN
  TOILETRIES
  AMENITIES
  CLEANING
}

model RoomSupplyItem {
  id                String                  @id @default(cuid())
  name              String
  category          RoomSupplyCategory
  unit              String
  stockQuantity     Int                     @default(0)
  lowStockThreshold Int                     @default(10)
  costPrice         Decimal                 @default(0) @db.Decimal(10, 2)
  requirements      RoomSupplyRequirement[]
  adjustments       RoomSupplyAdjustment[]
}

// Par level: how many units of a supply item a given room type needs per clean.
model RoomSupplyRequirement {
  id               String         @id @default(cuid())
  roomTypeId       String
  roomType         RoomType       @relation(fields: [roomTypeId], references: [id])
  supplyItemId     String
  supplyItem       RoomSupplyItem @relation(fields: [supplyItemId], references: [id])
  quantityPerClean Int

  @@unique([roomTypeId, supplyItemId])
}

// Audit trail for both restocks (positive quantityChange) and turnover consumption
// (negative, roomId set) of central room-supply stock.
model RoomSupplyAdjustment {
  id             String         @id @default(cuid())
  supplyItemId   String
  supplyItem     RoomSupplyItem @relation(fields: [supplyItemId], references: [id])
  quantityChange Int
  reason         String
  roomId         String?
  room           Room?          @relation(fields: [roomId], references: [id])
  staffId        String?
  staff          Staff?         @relation(fields: [staffId], references: [id])
  createdAt      DateTime       @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Restaurant module
// ─────────────────────────────────────────────────────────────────────────

enum TableStatus {
  FREE
  OCCUPIED
}

enum OrderStatus {
  OPEN
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  ROOM_CHARGE
}

enum OrderItemPrepStatus {
  RECEIVED
  PREPARING
  READY
  SERVED
}

model MenuCategory {
  id    String     @id @default(cuid())
  name  String
  items MenuItem[]
}

model MenuItem {
  id                    String               @id @default(cuid())
  name                  String
  categoryId            String
  category              MenuCategory         @relation(fields: [categoryId], references: [id])
  price                 Decimal              @db.Decimal(10, 2)
  isAvailable           Boolean              @default(true)
  // null = unlimited kitchen-prepared item; non-null = stock-tracked (e.g. transferred from a liquor store)
  stockQuantity         Int?
  lowStockThreshold     Int?
  sourceLiquorProductId String?              @unique
  sourceLiquorProduct   LiquorProduct?       @relation(fields: [sourceLiquorProductId], references: [id])
  orderItems            OrderItem[]
  // Bill of materials: kitchen-prepared items without a recipe are treated as unlimited,
  // same as an empty stockQuantity — recipes are how food-cost items get stock-tracked.
  recipe                MenuItemIngredient[]
}

model RestaurantTable {
  id     String      @id @default(cuid())
  number String      @unique
  seats  Int
  status TableStatus @default(FREE)
  orders Order[]
}

model Order {
  id                    String                 @id @default(cuid())
  tableId               String?
  table                 RestaurantTable?       @relation(fields: [tableId], references: [id])
  bookingId             String?
  booking               Booking?               @relation(fields: [bookingId], references: [id])
  assignedStaffId       String?
  assignedStaff         Staff?                 @relation(fields: [assignedStaffId], references: [id])
  status                OrderStatus            @default(OPEN)
  items                 OrderItem[]
  payments              Payment[]
  createdAt             DateTime               @default(now())
  closedAt              DateTime?
  ingredientAdjustments IngredientAdjustment[]
}

model OrderItem {
  id         String              @id @default(cuid())
  orderId    String
  order      Order               @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id])
  quantity   Int
  unitPrice  Decimal             @db.Decimal(10, 2)
  notes      String?
  prepStatus OrderItemPrepStatus @default(RECEIVED)
  voided     Boolean             @default(false)
  voidReason String?
  voidedAt   DateTime?
}

model Payment {
  id      String        @id @default(cuid())
  orderId String
  order   Order         @relation(fields: [orderId], references: [id])
  amount  Decimal       @db.Decimal(10, 2)
  method  PaymentMethod
  paidAt  DateTime      @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Kitchen ingredient inventory — raw materials the kitchen cooks with, distinct
// from MenuItem.stockQuantity (which tracks finished/purchased goods like bar
// drinks). MenuItemIngredient is the recipe (bill of materials): how much of
// each ingredient one serving needs. Adding an order item for a recipe-backed
// dish consumes those quantities from stock (and blocks — "86's" the dish —
// if there isn't enough left); voiding an item restores them. Kitchen items
// with no recipe rows stay unlimited, same as null MenuItem.stockQuantity.
// ─────────────────────────────────────────────────────────────────────────

enum IngredientCategory {
  PROTEIN
  PRODUCE
  DAIRY
  PANTRY
  BEVERAGE
  FROZEN
  BAKERY
}

model RestaurantIngredient {
  id                String                 @id @default(cuid())
  name              String
  category          IngredientCategory
  unit              String
  stockQuantity     Decimal                @default(0) @db.Decimal(10, 3)
  lowStockThreshold Decimal                @default(0) @db.Decimal(10, 3)
  costPerUnit       Decimal                @default(0) @db.Decimal(10, 2)
  supplier          String?
  recipes           MenuItemIngredient[]
  adjustments       IngredientAdjustment[]
}

// Par level per serving: how much of an ingredient one unit of a menu item consumes.
model MenuItemIngredient {
  id                 String               @id @default(cuid())
  menuItemId         String
  menuItem           MenuItem             @relation(fields: [menuItemId], references: [id])
  ingredientId       String
  ingredient         RestaurantIngredient @relation(fields: [ingredientId], references: [id])
  quantityPerServing Decimal              @db.Decimal(10, 3)

  @@unique([menuItemId, ingredientId])
}

// Audit trail for restocks (positive quantityChange), order-fulfillment consumption
// (negative, orderId set), and void reversals (positive, orderId set).
model IngredientAdjustment {
  id             String               @id @default(cuid())
  ingredientId   String
  ingredient     RestaurantIngredient @relation(fields: [ingredientId], references: [id])
  quantityChange Decimal              @db.Decimal(10, 3)
  reason         String
  orderId        String?
  order          Order?               @relation(fields: [orderId], references: [id])
  staffId        String?
  staff          Staff?               @relation(fields: [staffId], references: [id])
  createdAt      DateTime             @default(now())
}

// ─────────────────────────────────────────────────────────────────────────
// Liquor stores module (supports multiple stores)
//
// A liquor store is a wholesale supplier — it never sells directly to guests.
// Its only "sale" is a wholesale transfer of stock to the restaurant, which
// then resells it at retail through its own bar (a MenuItem, see above).
// ─────────────────────────────────────────────────────────────────────────

model LiquorStore {
  id        String           @id @default(cuid())
  name      String
  location  String?
  products  LiquorProduct[]
  transfers LiquorTransfer[]
}

model LiquorProduct {
  id                 String            @id @default(cuid())
  storeId            String
  store              LiquorStore       @relation(fields: [storeId], references: [id])
  name               String
  category           String?
  unitPrice          Decimal           @db.Decimal(10, 2)
  costPrice          Decimal           @db.Decimal(10, 2)
  stockQuantity      Int               @default(0)
  lowStockThreshold  Int               @default(5)
  adjustments        StockAdjustment[]
  transfers          LiquorTransfer[]
  restaurantMenuItem MenuItem?
}

// A wholesale shipment of stock from a liquor store to the restaurant's bar.
// wholesalePrice snapshots the store's unit price at transfer time (for accurate
// historical valuation even if the product's price changes later); retailPrice is
// what the restaurant then charges guests for it.
model LiquorTransfer {
  id             String        @id @default(cuid())
  storeId        String
  store          LiquorStore   @relation(fields: [storeId], references: [id])
  productId      String
  product        LiquorProduct @relation(fields: [productId], references: [id])
  quantity       Int
  wholesalePrice Decimal       @db.Decimal(10, 2)
  retailPrice    Decimal       @db.Decimal(10, 2)
  staffId        String
  staff          Staff         @relation(fields: [staffId], references: [id])
  createdAt      DateTime      @default(now())
}

model StockAdjustment {
  id             String        @id @default(cuid())
  productId      String
  product        LiquorProduct @relation(fields: [productId], references: [id])
  quantityChange Int
  reason         String
  createdAt      DateTime      @default(now())
}
